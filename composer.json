{
    "name": "psc-acme/renderer-cart",
    "description": "Package renderer-cart for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\RendererCart\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "psr/log": "^3.0",
        "symfony/dotenv": "^7.0"
    },
    "require-dev": {
        "infection/infection": "^0.27",
        "mockery/mockery": "^1.6"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}